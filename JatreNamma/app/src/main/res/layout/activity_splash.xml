<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@color/saffron_dark"
    android:padding="32dp">

    <TextView
        android:id="@+id/splash_logo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🏛️"
        android:textSize="80sp"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:id="@+id/splash_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ಜಾತ್ರೆ-ನಮ್ಮ"
        android:textSize="36sp"
        android:textColor="@android:color/white"
        android:textStyle="bold"
        android:fontFamily="sans-serif-medium"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Jatre-Namma Pride"
        android:textSize="20sp"
        android:textColor="#FFE0B2"
        android:layout_marginTop="4dp"/>

    <TextView
        android:id="@+id/splash_subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Your Digital Guide to the Village Fair"
        android:textSize="14sp"
        android:textColor="#FFCCBC"
        android:layout_marginTop="16dp"/>

</LinearLayout>
