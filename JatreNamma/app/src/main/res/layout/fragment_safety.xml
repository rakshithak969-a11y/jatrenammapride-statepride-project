<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF8F0">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/saffron_dark"
            android:padding="16dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🚨 Safety &amp; Help"
                android:textColor="@android:color/white"
                android:textSize="20sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Emergency Contacts"
                android:textSize="18sp" android:textStyle="bold"
                android:textColor="@color/saffron_dark"
                android:layout_marginBottom="12dp"/>

            <Button
                android:id="@+id/btn_call_ambulance"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="🏥  Ambulance — 108"
                android:backgroundTint="#C62828"
                android:textColor="@android:color/white"
                android:textSize="18sp"
                android:layout_marginBottom="12dp"/>

            <Button
                android:id="@+id/btn_call_police"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="👮  Police — 100"
                android:backgroundTint="#1565C0"
                android:textColor="@android:color/white"
                android:textSize="18sp"
                android:layout_marginBottom="12dp"/>

            <Button
                android:id="@+id/btn_call_fire"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="🚒  Fire Brigade — 101"
                android:backgroundTint="#E65100"
                android:textColor="@android:color/white"
                android:textSize="18sp"
                android:layout_marginBottom="12dp"/>

            <Button
                android:id="@+id/btn_call_organizer"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="📞  Jatre Organizer"
                android:backgroundTint="#2E7D32"
                android:textColor="@android:color/white"
                android:textSize="18sp"
                android:layout_marginBottom="24dp"/>

            <!-- Safety Guidelines -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Safety Guidelines"
                android:textSize="18sp" android:textStyle="bold"
                android:textColor="@color/saffron_dark"
                android:layout_marginBottom="12dp"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="8dp" app:cardElevation="2dp">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:padding="14dp"
                    android:text="✅  Keep children close at all times during Ratha procession\n\n✅  Designated first aid post is near the main temple\n\n✅  Parking zones are marked — do not park on procession route\n\n✅  Lost child? Go to the Help Desk near the temple gate\n\n✅  In case of crowd surge, move sideways, not against the flow\n\n✅  Carry your ID card at all times\n\n✅  Avoid carrying large bags in crowded areas"
                    android:textSize="14sp" android:textColor="#444" android:lineSpacingExtra="4dp"/>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </LinearLayout>
</ScrollView>
